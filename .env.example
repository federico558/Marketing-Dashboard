# Vercel Postgres (auto-provisioned)
POSTGRES_PRISMA_URL="postgres://..."
POSTGRES_URL_NON_POOLING="postgres://..."

# NextAuth / Auth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Resend (email magic link)
AUTH_RESEND_KEY="re_..."
EMAIL_FROM="onboarding@resend.dev"

# Comma-separated allowlist of emails that can sign in. Leave unset to allow any email.
AUTH_ALLOWED_EMAILS=""

# Google OAuth (GA4 + Search Console)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Encryption key for stored OAuth tokens and API keys (32 bytes hex)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# App URL (used for OAuth callbacks)
APP_URL="http://localhost:3000"
