# Postgres (Neon, Supabase, or local)
DATABASE_URL="postgresql://user:pass@host:5432/marketing_dashboard"

# NextAuth / Auth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Resend (email magic link)
AUTH_RESEND_KEY="re_..."
EMAIL_FROM="Marketing Dashboard <noreply@yourdomain.com>"

# Windsor.ai
WINDSOR_API_KEY=""
WINDSOR_API_BASE="https://api.windsor.ai"

# App URL (used for OAuth callbacks)
APP_URL="http://localhost:3000"
